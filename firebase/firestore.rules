rules_version = '2';

// ============================================================
// FranciOS - Firestore Security Rules
// Principio: Privacy First. Cada usuario so acessa os proprios
// dados. Nenhum documento e legivel/gravavel por outro usuario
// ou por clientes nao autenticados.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Perfil do usuario e submodulos da vida
    // (saude, sono, financas, habitos, estudos, humor, etc.).
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Serie historica do Life Score, gerada pelo Life Engine
      // (backend/functions/src/engines/lifeEngine.ts). E um registro
      // derivado/auditavel: o dono pode ler, mas apenas o backend
      // (Cloud Functions via Admin SDK) pode escrever, para impedir
      // que o cliente falsifique a evolucao do proprio Life Score.
      //
      // IMPORTANTE: como esta subcolecao NAO pode ser gravavel pelo
      // cliente, nao usamos um wildcard {subcollection} generico (que
      // concederia escrita a qualquer subcolecao, inclusive esta).
      // Cada subcolecao e listada explicitamente abaixo.
      match /lifeScoreHistory/{entryId} {
        allow read: if isOwner(userId);
        allow write: if false; // apenas Cloud Functions (Admin SDK)
      }

      // Eventos de vida registrados pelo Event Engine. O cliente
      // cria/le os proprios eventos; o recalculo do Life Score e
      // feito pelo backend a partir deles.
      match /events/{eventId} {
        allow read, write: if isOwner(userId);
      }

      // Demais submodulos da vida sob controle total do dono
      // (saude, sono, financas, habitos, estudos, humor, etc.),
      // exceto colecoes derivadas listadas explicitamente acima.
      match /modules/{moduleId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Memoria/contexto gerado pelo Memory Engine - somente o
    // backend (Cloud Functions, via Admin SDK) deve escrever aqui.
    match /memory/{userId}/{document=**} {
      allow read: if isOwner(userId);
      allow write: if false; // apenas Cloud Functions (Admin SDK)
    }

    // Previsoes geradas pelo Prediction Engine - somente leitura
    // pelo dono; escrita restrita ao backend.
    match /predictions/{userId}/{document=**} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    // Ranking global opcional - leitura publica de dados ja
    // anonimizados/agregados, sem nenhuma informacao privada.
    match /rankingGlobal/{entryId} {
      allow read: if isSignedIn();
      allow write: if false; // apenas Cloud Functions
    }

    // Bloqueio padrao: qualquer caminho nao listado acima e negado.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
